{
  "info": {
    "name": "BankFlow API",
    "description": "Postman collection for BankFlow API demo flows: auth, accounts, money movement, transfers, ledger, admin audit logs, and reconciliation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "customerEmail", "value": "customer@bankflow.dev" },
    { "key": "customerPassword", "value": "Customer123!" },
    { "key": "adminEmail", "value": "admin@bankflow.dev" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "customerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "accountId", "value": "" }
  ],
  "item": [
    {
      "name": "Customer Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('customerToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "Create Account",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accountId', json.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/accounts",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"CHECKING\"\n}"
        }
      }
    },
    {
      "name": "Deposit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/accounts/{{accountId}}/deposit",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": \"100.00\",\n  \"description\": \"Postman deposit\"\n}"
        }
      }
    },
    {
      "name": "Transfer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Idempotency-Key", "value": "postman-transfer-001" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/transfers",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sourceAccountId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"destinationAccountId\": \"{{accountId}}\",\n  \"amount\": \"25.00\",\n  \"description\": \"Postman internal transfer\"\n}"
        }
      }
    },
    {
      "name": "Ledger",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
        "url": "{{baseUrl}}/api/accounts/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/ledger"
      }
    },
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminToken', json.data.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        }
      }
    },
    {
      "name": "Admin Audit Logs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/audit-logs"
      }
    },
    {
      "name": "Admin Reconciliation",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/reconciliation"
      }
    }
  ]
}
