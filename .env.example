DATABASE_URL=jdbc:postgresql://postgres:5432/bankflow
DATABASE_USERNAME=bankflow
DATABASE_PASSWORD=bankflow
JWT_SECRET=replace-with-a-strong-256-bit-or-longer-secret
JWT_ISSUER=bankflow-api
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14
JWT_REFRESH_TOKEN_CLEANUP_CRON=0 15 3 * * *
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SERVER_PORT=8080
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_REFILL_PER_MINUTE=120
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_KEY_PREFIX=bankflow:rate-limit
RATE_LIMIT_REDIS_FAIL_OPEN=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s
REDIS_HEALTH_ENABLED=true
TRANSFER_REVIEW_THRESHOLD=10000.00
